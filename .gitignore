# PRAMAN — heavy/transient artifacts stay out of git (kept on the box, synced selectively)
.venv/
.cache/
__pycache__/
*.pyc
*.egg-info/
build/
dist/

# data + model + run outputs (regenerated by scripts/)
data/
embeddings/
models/
*.onnx
*.bin
*.safetensors

# large run artifacts; small numeric artifacts (thresholds, calib params, metrics json) ARE tracked
runs/*/raw/
runs/*/*.parquet
runs/*/*.npy

# secrets
.env
*.pem
*.key

# os
.DS_Store
Thumbs.db
